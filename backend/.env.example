# =============================================================================
# finance.qyzar.eu backend — environment variables
# Copy this file to .env and fill in your values. Never commit .env (gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# WebSocket server (src/index.ts)
# -----------------------------------------------------------------------------
WS_PORT=3000
ws_port=3000

# -----------------------------------------------------------------------------
# PostgreSQL
# Use DATABASE_URL *or* the individual postgres_* / PG* variables.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
postgres_user=
postgres_password=
postgres_host=localhost
postgres_port=5432
postgres_database=

# -----------------------------------------------------------------------------
# Alpha Vantage — equities, fundamentals, earnings, technical indicators
# Free key: https://www.alphavantage.co/support/#api-key
# -----------------------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=
alphavantage_api_key=

# -----------------------------------------------------------------------------
# FMP (Financial Modeling Prep) — quotes, financials, news, technical indicators
# Free key: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 API calls/day. HTTP 402 = daily quota exhausted.
# FMP_DAILY_LIMIT=250          # hard daily cap tracked by the backend
# FMP_DAILY_RESERVE=10         # stop using FMP before the cap (fallback earlier)
# FMP_CACHE_TTL_MS=14400000    # cache responses 4h to preserve quota (default)
# -----------------------------------------------------------------------------
FMP_API_KEY=
fmp_api_key=

# -----------------------------------------------------------------------------
# Massive / Polygon.io — market aggregates, snapshots, news, financials
# Free key: https://polygon.io/dashboard/signup
# -----------------------------------------------------------------------------
MASSIVE_API_KEY=
POLYGON_API_KEY=
massive_api_key=
polygon_api_key=

# -----------------------------------------------------------------------------
# Finnhub — quotes, candles, news, fundamentals, sentiment
# Free key: https://finnhub.io/register
# -----------------------------------------------------------------------------
FINNHUB_API_KEY=
finnhub_api_key=

# -----------------------------------------------------------------------------
# CoinGecko — cryptocurrency prices and market data
# Optional demo key: https://www.coingecko.com/en/api/pricing
# No key required for public endpoints.
# Optional config:
# COINGECKO_API_KEY=
# COINGECKO_API_TIER=demo
# COINGECKO_CACHE_TTL_MS=300000
# COINGECKO_STALE_MAX_MS=604800000
# CRYPTO_TICKER_CACHE_TTL_MS=300000
# COINGECKO_CHART_CACHE_TTL_MS=900000
# COINGECKO_CHART_STALE_MS=86400000
# COINGECKO_REFRESH_CRON=*/5 * * * *
# COINGECKO_REFRESH_ON_STARTUP=true
# COINGECKO_REFRESH_CHART_SYMBOLS=BTC,ETH,SOL,XRP,BNB
# COINGECKO_REFRESH_TICKER_LIMIT=15
# COINGECKO_REFRESH_CHART_DAYS=7
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Currents API — global news headlines and search
# Get a key: https://currentsapi.services/en/register
# -----------------------------------------------------------------------------
CURRENTSAPI_API_KEY=
currentsapi_api_key=

# -----------------------------------------------------------------------------
# The Guardian — UK/international editorial news
# Get a key: https://open-platform.theguardian.com/access/
# -----------------------------------------------------------------------------
GUARDIAN_API_KEY=
guardian_api_key=

# -----------------------------------------------------------------------------
# GDELT — geopolitics, media tone, timelines (no API key required)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# RSS — government & regulatory feeds (no API key required)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Reddit — retail sentiment and discussion
# Create app: https://www.reddit.com/prefs/apps
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=your-app-name/1.0 by /u/yourusername
reddit_client_id=
reddit_client_secret=
reddit_user_agent=your-app-name/1.0 by /u/yourusername

# -----------------------------------------------------------------------------
# Google Trends — search interest signals (optional SerpAPI key)
# SerpAPI: https://serpapi.com/manage-api-key
# -----------------------------------------------------------------------------
SERPAPI_API_KEY=
serpapi_api_key=

# -----------------------------------------------------------------------------
# DeepAI / AI provider — LLM backend for agents
# src/providers/ai/deepai.ts is gitignored. Copy deepai.boilerplate.ts to
# deepai.ts and implement callDeepAI / streamDeepAI with your own provider.
# No environment variable required unless your provider needs one.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# FRED — St. Louis Fed economic data
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# -----------------------------------------------------------------------------
FRED_API_KEY=
fred_api_key=

# -----------------------------------------------------------------------------
# U.S. Census Data API
# Free key: https://api.census.gov/data/key_signup.html
# -----------------------------------------------------------------------------
CENSUS_API_KEY=
census_api_key=

# -----------------------------------------------------------------------------
# LDA.gov — federal lobbying disclosures
# Register: https://lda.gov/api/register/
# -----------------------------------------------------------------------------
LDA_API_KEY=
lda_api_key=

# -----------------------------------------------------------------------------
# SEC EDGAR — filings and XBRL financial data (no API key)
# Requires a descriptive User-Agent with a contact email.
# Policy: https://www.sec.gov/os/webmaster-faq#code-support
# -----------------------------------------------------------------------------
SEC_USER_AGENT=your-app-name your@email.com
sec_user_agent=your-app-name your@email.com

# -----------------------------------------------------------------------------
# USAspending.gov — federal contracts, grants, spending (no API key)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# GNews — news search and top headlines
# Get a key: https://gnews.io/
# Set GNEWS_ENABLED=false to disable (disabled by default due to API timeouts)
# -----------------------------------------------------------------------------
GNEWS_ENABLED=false
GNEWS_API_KEY=
gnews_api_key=

# -----------------------------------------------------------------------------
# StockTwits — retail ticker sentiment (optional)
# Register app: https://api.stocktwits.com/developers
# -----------------------------------------------------------------------------
STOCKTWITS_CLIENT_ID=
stocktwits_client_id=

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging — push notifications
# Download a service account JSON from Firebase Console > Project Settings >
# Service Accounts > Generate new private key.
# Provide either the path or the three individual credential fields.
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Scheduler and agent settings
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SYSTEM_ACCOUNT_ID=00000000-0000-0000-0000-000000000001

# Discovery pipeline cron schedule
DISCOVERY_CRON=0 * * * *

# Monitoring tiers
MONITOR_P1_CRON=0 * * * *
MONITOR_P2_CRON=0 */6 * * *
MONITOR_P3_CRON=0 5 * * *
MONITOR_BATCH_SIZE=20

# Event detection
EVENT_POLL_CRON=*/15 * * * *
EVENT_AI_ENABLED=true
EVENT_MAX_HEADLINES=180
EVENT_HEADLINE_BATCH_SIZE=50
EVENT_MAX_PER_TICK=5

# Watchlist
WATCHLIST_NASDAQ_SEED=true
WATCHLIST_NASDAQ_SEED_LIMIT=500
WATCHLIST_P1_INTERVAL_MS=3600000
WATCHLIST_P2_INTERVAL_MS=21600000
WATCHLIST_P3_INTERVAL_MS=86400000

# Watchlist reviewer (runs weeknights after US close)
WATCHLIST_REVIEWER_CRON=0 21 * * 1-5
SCHEDULER_TIMEZONE=America/New_York
WATCHLIST_REVIEWER_MAX_COMPANIES=100
WATCHLIST_REVIEWER_MAX_CORRELATIONS=12

# Correlation
CORRELATION_LOOKBACK_MS=3600000
CORRELATION_MAX_PER_RUN=5

# Agent models — set the default or override per-agent
AGENT_MODEL=gpt-4o
AGENT_MODEL_COMMODITIES=gpt-4o
AGENT_MODEL_CRYPTO_ANALYSIS=gpt-4o
AGENT_MODEL_MACROECONOMIC=gpt-4o
AGENT_MODEL_FUTURE_OPPORTUNIST=gpt-4o
AGENT_MODEL_CONSERVATIONIST=gpt-4o
AGENT_MODEL_INDUSTRY_SURGE=gpt-4o
AGENT_MODEL_REGULATORY_DISCOVERY=gpt-4o
AGENT_MODEL_RISK_POLITICAL=gpt-4o
AGENT_MODEL_RISK_GOVERNANCE=gpt-4o
AGENT_MODEL_RISK_FINANCIAL=gpt-4o
AGENT_MODEL_RISK_MARKET=gpt-4o
AGENT_MODEL_RISK_REPUTATION=gpt-4o
AGENT_MODEL_DOSSIER=gpt-4o
AGENT_MODEL_SHORTFALL=gpt-4o
WIDGET_AGENT_ENABLED=true

# Agent iteration limits
AGENT_MAX_TOOL_ITERATIONS=100
AGENT_MAX_RESEARCH_PASSES=50
AGENT_MAX_IDLE_PASSES=3
DEEPAI_REQUEST_TIMEOUT_MS=120000

# Cache TTLs (milliseconds)
PUBLIC_STOCK_CACHE_TTL_MS=900000
CHART_DAILY_CACHE_TTL_MS=21600000
CHART_INTRADAY_CACHE_TTL_MS=300000
CACHE_DEFAULT_TTL_MS=3600000
CACHE_HOT_TTL_MS=60000
CACHE_WARM_TTL_MS=900000
CACHE_MEDIUM_TTL_MS=14400000
CACHE_COLD_TTL_MS=21600000
CACHE_STATIC_TTL_MS=604800000
CACHE_STALE_MAX_MS=604800000
CACHE_PURGE_CRON=0 3 * * *

# API health check
API_HEALTH_CHECK_ENABLED=true
API_HEALTH_CHECK_CRON=*/5 * * * *
API_HEALTH_CHECK_ON_STARTUP=true
